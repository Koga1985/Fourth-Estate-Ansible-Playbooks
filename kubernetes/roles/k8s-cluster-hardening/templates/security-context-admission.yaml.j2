# REVIEW REQUIRED before production. Validates Pod Security Admission defaults.
# See KNOWN_LIMITATIONS.md (#13).
apiVersion: apiserver.config.k8s.io/v1
kind: AdmissionConfiguration
plugins:
  - name: PodSecurity
    configuration:
      apiVersion: pod-security.admission.config.k8s.io/v1
      kind: PodSecurityConfiguration
      defaults:
        enforce: "{{ k8s_psa_enforce | default('restricted') }}"
        enforce-version: "{{ k8s_psa_version | default('latest') }}"
        audit: "{{ k8s_psa_audit | default('restricted') }}"
        warn: "{{ k8s_psa_warn | default('restricted') }}"
      exemptions:
        namespaces: {{ k8s_psa_exempt_namespaces | default(['kube-system']) | to_json }}
