# Managed by Ansible (k8s-cluster-hardening) - forward k8s audit log via rsyslog
# REVIEW REQUIRED before production (set k8s_rsyslog_remote to enable forwarding).
module(load="imfile")
input(type="imfile"
      File="{{ k8s_audit_log_path | default('/var/log/kubernetes/audit.log') }}"
      Tag="k8s-audit:"
      Severity="info")
{% if k8s_rsyslog_remote is defined %}
*.* @@{{ k8s_rsyslog_remote }}
{% endif %}
