---
# Kubernetes — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# NOTE: Kubernetes roles use the kubernetes.core collection which reads
# credentials from your kubeconfig file, NOT from vault variables.
#
# Before running:
#   export KUBECONFIG=/path/to/your/kubeconfig
#   kubectl cluster-info   # verify connectivity
#
# If you need to store kubeconfig credentials in vault, set:

vault_k8s_api_server: "https://k8s-api.example.com:6443"
vault_k8s_api_token: "CHANGE_ME"    # Service account token with cluster-admin
vault_k8s_ca_cert: |
  -----BEGIN CERTIFICATE-----
  CHANGE_ME
  -----END CERTIFICATE-----
