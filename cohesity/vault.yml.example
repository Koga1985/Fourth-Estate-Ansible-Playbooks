---
# Cohesity Data Protection — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ---- Cohesity cluster credentials -------------------------------------------
vault_cohesity_username: "admin"                # Cluster admin username
vault_cohesity_password: "CHANGE_ME"            # Cluster admin password
vault_cohesity_admin_password: "CHANGE_ME"      # Alternate admin password (for cluster_install role)

# ---- License key ------------------------------------------------------------
vault_cohesity_license: "CHANGE_ME"             # Cohesity cluster license key

# ---- Specialized service accounts -------------------------------------------
vault_backup_operator_password: "CHANGE_ME"     # Backup operator account password
vault_security_admin_password: "CHANGE_ME"      # Security admin account password

# ---- LDAP / Active Directory integration ------------------------------------
vault_ldap_password: "CHANGE_ME"                # LDAP/AD bind account password
vault_ad_password: "CHANGE_ME"                  # AD join account password

# ---- vCenter integration (for VMware workload protection) -------------------
vault_vcenter_password: "CHANGE_ME"

# ---- SMTP relay (for alerts) ------------------------------------------------
vault_smtp_password: "CHANGE_ME"

# ---- SNMP authentication ----------------------------------------------------
vault_snmp_auth_password: "CHANGE_ME"
vault_snmp_privacy_password: "CHANGE_ME"

# ---- IPMI / iDRAC (if performing node-level operations) ---------------------
vault_ipmi_password: "CHANGE_ME"
