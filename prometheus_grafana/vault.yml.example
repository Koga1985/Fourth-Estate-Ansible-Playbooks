---
# Prometheus & Grafana — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ---- Grafana admin account --------------------------------------------------
vault_grafana_admin_password: "CHANGE_ME"      # Grafana admin user password (used in inventory)

# ---- Database exporter credentials (only if monitoring these databases) -----
vault_postgres_exporter_password: "CHANGE_ME"  # postgres_exporter service account password
vault_mysql_exporter_password: "CHANGE_ME"     # mysqld_exporter service account password
