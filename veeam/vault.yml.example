---
# Veeam Backup & Replication — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ---- Veeam server OS credentials (WinRM connection) -------------------------
vault_windows_password: "CHANGE_ME"             # Windows admin password for Veeam server
vault_linux_password: "CHANGE_ME"               # Linux password for Linux backup repositories

# ---- Backup encryption passwords --------------------------------------------
vault_encryption_password: "CHANGE_ME"                    # Default backup job encryption password
vault_veeam_editorial_encryption_password: "CHANGE_ME"    # Editorial data encryption password
vault_veeam_immutable_encryption_password: "CHANGE_ME"    # Immutable backup encryption password
vault_veeam_database_encryption_password: "CHANGE_ME"     # Veeam config database encryption
vault_veeam_linux_repo_password: "CHANGE_ME"              # Linux hardened repo encryption

# ---- Cloud repository credentials ------------------------------------------
# AWS S3
vault_s3_access_key: "CHANGE_ME"
vault_s3_secret_key: "CHANGE_ME"

# Azure Blob Storage
vault_azure_storage_account_name: "CHANGE_ME"
vault_azure_storage_account_key: "CHANGE_ME"

# Google Cloud Storage
vault_gcs_access_key: "CHANGE_ME"
vault_gcs_secret_key: "CHANGE_ME"

# ---- VMware vCenter integration ---------------------------------------------
vault_vmware_password: "CHANGE_ME"             # vCenter service account password
