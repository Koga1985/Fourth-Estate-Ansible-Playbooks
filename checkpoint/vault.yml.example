---
# Check Point Firewalls — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ---- Management Server credentials ------------------------------------------
vault_checkpoint_username: "admin"
vault_checkpoint_password: "CHANGE_ME"

# ---- VPN / Identity Awareness credentials -----------------------------------
vault_branch1_psk: "CHANGE_ME"   # Site-to-site VPN pre-shared key for branch1
vault_ia_pwd: "CHANGE_ME"        # Identity Awareness shared secret
