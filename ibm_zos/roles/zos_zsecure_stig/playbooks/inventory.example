# Example inventory for the zos_zsecure_stig role.
# Checklist runs on localhost. For LIVE read-only assessment, define the z/OS
# LPAR and pass -e zos_target=zos-lpar-01.
[local]
localhost ansible_connection=local

[zos]
zos-lpar-01 ansible_host=mainframe.example.mil ansible_user=ZAUTO

[zos:vars]
ansible_python_interpreter=/usr/lpp/IBM/cyp/v3r11/pyz/bin/python3
