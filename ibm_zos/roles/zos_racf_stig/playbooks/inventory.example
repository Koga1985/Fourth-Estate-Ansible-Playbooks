# Example inventory for the z/OS RACF STIG role.
# The role generates the checklist on the control node (localhost). For LIVE
# read-only assessment, define the z/OS LPAR and pass -e zos_target=zos-lpar-01.
[local]
localhost ansible_connection=local

[zos]
zos-lpar-01 ansible_host=mainframe.example.mil ansible_user=ZAUTO

[zos:vars]
# ibm.ibm_zos_core requires z/OS Python + ZOAU on the managed node:
ansible_python_interpreter=/usr/lpp/IBM/cyp/v3r11/pyz/bin/python3
# environment for ZOAU (adjust to your install):
# _BPXK_AUTOCVT=ON
# ZOAU_HOME=/usr/lpp/IBM/zoautil
