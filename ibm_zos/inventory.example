# IBM z/OS STIG Assessment Inventory Example
# Copy this file to 'inventory' and customize for your environment:
#   cp inventory.example inventory
#
# Checklist mode (default) runs entirely on the control node — no mainframe
# is contacted:
#   ansible-playbook roles/zos_racf_stig/playbooks/run.yml -i inventory
#
# Live read-only assessment additionally requires z/OS Python + ZOAU + SSH
# on the LPAR (see requirements.yml):
#   ansible-playbook roles/zos_racf_stig/playbooks/run.yml -i inventory \
#     -e zos_live_assessment=true -e zos_target=zos-lpar-01

[localhost]
localhost ansible_connection=local

# --- z/OS LPARs (used only when zos_live_assessment=true) ---
[zos_lpars]
# zos-lpar-01 ansible_host=192.168.1.100 ansible_user=automation
# zos-lpar-02 ansible_host=192.168.1.101 ansible_user=automation

[zos_lpars:vars]
# Paths to the z/OS Python and ZOAU installs on the managed node
# ansible_python_interpreter=/usr/lpp/IBM/cyp/v3r12/pyz/bin/python3
# environment_vars: see ibm.ibm_zos_core documentation
