# Example inventory for the RHEL 9 STIG role.
# Copy to `inventory` and edit. Use Ansible Vault / SSH keys for credentials.
[rhel9]
web01 ansible_host=10.0.0.81
web02 ansible_host=10.0.0.82

[rhel9:vars]
ansible_user=ansible
ansible_become=true
ansible_become_method=sudo
# ansible_ssh_private_key_file=~/.ssh/ansible
