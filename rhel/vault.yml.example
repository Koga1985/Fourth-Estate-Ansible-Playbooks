---
# Red Hat Enterprise Linux — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# NOTE: RHEL roles connect via SSH using become (sudo). The primary credentials
# are the SSH user/password (or SSH key) and the sudo password.

# ---- SSH connection credentials (set one of the following) ------------------
# Option A: password-based SSH (less preferred)
vault_ansible_user: "ansible"
vault_ansible_password: "CHANGE_ME"
vault_ansible_become_password: "CHANGE_ME"   # sudo password (if different from above)

# Option B: SSH key-based (preferred — leave password vars empty)
# Configure ssh_key in your inventory or ansible.cfg instead.

# ---- RHEL subscription credentials (required for yum/dnf updates) ----------
vault_rhsm_username: "CHANGE_ME"    # Red Hat subscription username
vault_rhsm_password: "CHANGE_ME"    # Red Hat subscription password
vault_rhsm_pool_id: ""              # Optional: specific subscription pool ID
