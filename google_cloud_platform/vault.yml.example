---
# Google Cloud Platform — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# NOTE: GCP authentication uses a service account JSON key file, NOT inline
# credentials. Set the environment variable before running:
#   export GCP_SERVICE_ACCOUNT_FILE=/path/to/service-account-key.json
#   export GCP_AUTH_KIND=serviceaccount
#
# The vault variables below are used for project/billing configuration only.

# ---- GCP Organization settings ----------------------------------------------
vault_gcp_org_id: "CHANGE_ME"        # GCP Organization ID (numeric, e.g. 123456789012)
vault_gcp_billing_account: "CHANGE_ME"  # Billing account ID (e.g. XXXXXX-XXXXXX-XXXXXX)
