---
# Amazon Web Services — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# NOTE: AWS authentication is handled via environment variables or IAM roles,
# NOT via Ansible vault variables. Set one of the following before running:
#
# Option A — Environment variables (recommended for CI/CD):
#   export AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
#   export AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
#   export AWS_DEFAULT_REGION="us-gov-west-1"
#
# Option B — Named AWS profile (~/.aws/credentials):
#   export AWS_PROFILE="fourth-estate-prod"
#
# Option C — IAM Instance Role (preferred for EC2 control nodes):
#   No credentials needed — IAM role provides access automatically.
#
# The variables below are optional overrides if you prefer vault storage.

# ---- Optional: store AWS credentials in vault instead of env vars -----------
# vault_aws_access_key_id: "CHANGE_ME"
# vault_aws_secret_access_key: "CHANGE_ME"
# vault_aws_session_token: ""          # required for temporary STS credentials

# ---- Optional: SNS / notification endpoints ---------------------------------
# vault_aws_sns_email: "alerts@example.com"
