# Example inventory for the F5 BIG-IP Device Management STIG role.
# BIG-IP is managed over iControl REST (httpapi) from the control node.
[bigips]
bigip-01 ansible_host=10.0.0.48

[bigips:vars]
ansible_connection=httpapi
ansible_network_os=f5networks.f5_modules.bigip
ansible_httpapi_use_ssl=true
ansible_httpapi_validate_certs=true
ansible_httpapi_port=443
ansible_user=admin
# ansible_password="{{ vault_f5_password }}"
