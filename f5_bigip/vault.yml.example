---
# F5 BIG-IP — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ---- Primary admin credentials (used in inventory.example) ------------------
vault_f5_username: "admin"
vault_f5_password: "CHANGE_ME"

# ---- Secondary admin account ------------------------------------------------
vault_f5_admin2_password: "CHANGE_ME"      # Backup / secondary admin password

# ---- Licensing --------------------------------------------------------------
vault_f5_license_key: "CHANGE_ME"          # BIG-IP base registration key (XXXXX-XXXXX-...)

# ---- SNMPv3 authentication --------------------------------------------------
vault_f5_snmp_auth_password: "CHANGE_ME"   # SNMPv3 auth password
vault_f5_snmp_priv_password: "CHANGE_ME"   # SNMPv3 privacy password

# ---- SSL certificate import -------------------------------------------------
vault_ssl_passphrase: "CHANGE_ME"          # Passphrase for SSL/TLS private key
vault_key_passphrase: "CHANGE_ME"          # Passphrase for client auth key (if applicable)
