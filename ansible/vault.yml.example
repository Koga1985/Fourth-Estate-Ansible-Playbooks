---
# Ansible Automation Platform — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ---- Automation Controller credentials --------------------------------------
vault_controller_username: "admin"
vault_controller_password: "CHANGE_ME"

# ---- Automation Hub (Private Automation Hub) credentials --------------------
vault_ah_username: "admin"
vault_ah_password: "CHANGE_ME"
