#!/usr/bin/env bash
# Managed by Ansible (postgresql_backup) - retention enforcement
set -euo pipefail
BACKUP_DIR="{{ postgresql_backup_directory | default('/var/backups/postgresql') }}"
find "${BACKUP_DIR}" -maxdepth 1 -name 'full_*'    -mtime +{{ postgresql_backup_retention_daily | default(7) }} -exec rm -rf {} \;
find "${BACKUP_DIR}" -maxdepth 1 -name 'logical_*' -mtime +{{ (postgresql_backup_retention_weekly | default(4) | int) * 7 }} -exec rm -f {} \;
echo "Cleanup completed for ${BACKUP_DIR}"
