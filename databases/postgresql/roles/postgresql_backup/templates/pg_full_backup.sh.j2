#!/usr/bin/env bash
# Managed by Ansible (postgresql_backup) - physical base backup
set -euo pipefail
BACKUP_DIR="{{ postgresql_backup_directory | default('/var/backups/postgresql') }}"
TS="$(date +%Y%m%d_%H%M%S)"
DEST="${BACKUP_DIR}/full_${TS}"
mkdir -p "${DEST}"
pg_basebackup \
  -h "{{ postgresql_host | default('localhost') }}" \
  -p "{{ postgresql_port | default(5432) }}" \
  -U "{{ postgresql_superuser | default('postgres') }}" \
  -D "${DEST}" -Ft -z -Xs -P
echo "Full backup completed: ${DEST}"
