# Managed by Ansible (postgresql_backup)
BACKUP_DIR="{{ postgresql_backup_directory | default('/var/backups/postgresql') }}"
PGHOST="{{ postgresql_host | default('localhost') }}"
PGPORT="{{ postgresql_port | default(5432) }}"
PGUSER="{{ postgresql_superuser | default('postgres') }}"
RETENTION_DAILY="{{ postgresql_backup_retention_daily | default(7) }}"
RETENTION_WEEKLY="{{ postgresql_backup_retention_weekly | default(4) }}"
RETENTION_MONTHLY="{{ postgresql_backup_retention_monthly | default(12) }}"
WAL_ARCHIVING="{{ postgresql_enable_wal_archiving | default(false) | lower }}"
