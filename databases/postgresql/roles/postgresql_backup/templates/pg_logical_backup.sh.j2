#!/usr/bin/env bash
# Managed by Ansible (postgresql_backup) - logical dump of all databases
set -euo pipefail
BACKUP_DIR="{{ postgresql_backup_directory | default('/var/backups/postgresql') }}"
TS="$(date +%Y%m%d_%H%M%S)"
mkdir -p "${BACKUP_DIR}"
pg_dumpall \
  -h "{{ postgresql_host | default('localhost') }}" \
  -p "{{ postgresql_port | default(5432) }}" \
  -U "{{ postgresql_superuser | default('postgres') }}" \
  | gzip > "${BACKUP_DIR}/logical_${TS}.sql.gz"
echo "Logical backup completed: ${BACKUP_DIR}/logical_${TS}.sql.gz"
