#!/usr/bin/env bash
# Managed by Ansible (postgresql_replication) - replication lag (seconds)
set -euo pipefail
psql -h "{{ postgresql_host | default('localhost') }}" -p "{{ postgresql_port | default(5432) }}" \
  -U "{{ postgresql_superuser | default('postgres') }}" -Atc \
  "SELECT CASE WHEN pg_is_in_recovery() THEN EXTRACT(EPOCH FROM (now() - pg_last_xact_replay_timestamp()))::int ELSE 0 END;"
