# Managed by Ansible (postgresql_replication) - standby recovery settings
# PostgreSQL 12+: settings live in postgresql.auto.conf + standby.signal; kept for <=11.
standby_mode = 'on'
primary_conninfo = 'host={{ postgresql_primary_host | default('') }} port={{ postgresql_port | default(5432) }} user={{ postgresql_replication_user | default('replicator') }} application_name={{ inventory_hostname }}'
recovery_target_timeline = 'latest'
