---
# PostgreSQL — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ---- PostgreSQL credentials -------------------------------------------------
vault_postgresql_superuser_password: "CHANGE_ME"    # 'postgres' OS/DB superuser password
vault_postgresql_admin_password: "CHANGE_ME"        # Application admin user password
vault_postgresql_replication_password: "CHANGE_ME"  # Streaming replication user password
