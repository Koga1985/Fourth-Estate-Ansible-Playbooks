# Example inventory for the Oracle Database STIG role.
# The role runs ON the database host and becomes the Oracle OS owner.
[oracle_servers]
ora-01 ansible_host=10.0.0.97

[oracle_servers:vars]
ansible_user=ansible
ansible_become=true
ansible_become_method=sudo
oracle_os_user=oracle
oracle_home=/u01/app/oracle/product/19.0.0/dbhome_1
oracle_sid=ORCL
