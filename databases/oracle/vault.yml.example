---
# Oracle Database — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# NOTE: The oracle roles connect via SSH to the DB host (become: true).
# Set ansible_user / ansible_password in inventory or via SSH keys.

# ---- Oracle OS and DB credentials -------------------------------------------
vault_oracle_sys_password: "CHANGE_ME"          # SYS / SYSDBA password
vault_oracle_system_password: "CHANGE_ME"       # SYSTEM user password
vault_oracle_asmsnmp_password: "CHANGE_ME"      # ASM monitoring password (if using ASM)
vault_oracle_dbsnmp_password: "CHANGE_ME"       # DB monitoring (DBSNMP) password
vault_oracle_rman_password: "CHANGE_ME"         # RMAN catalog user password (if using catalog)
