---
# MySQL / MariaDB — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ---- MySQL credentials ------------------------------------------------------
vault_mysql_root_password: "CHANGE_ME"          # MySQL root password
vault_mysql_replication_password: "CHANGE_ME"   # Replication user password
vault_mysql_sst_user: "sst_user"                # Galera SST user (XtraBackup)
vault_mysql_sst_password: "CHANGE_ME"           # Galera SST user password
