{{ ansible_managed | comment }}
# DISA MongoDB Enterprise STIG hardened mongod.conf - {{ stig_benchmark }} {{ stig_version }}
# Review the dry-run diff before enforcing; site-specific tuning must be merged here.

storage:
  dbPath: {{ mongodb_storage_dbpath }}

systemLog:
  destination: file
  logAppend: true
  path: {{ mongodb_systemlog_path }}

net:
  port: {{ mongodb_port }}
  bindIp: {{ mongodb_bind_ip }}
  tls:
    mode: {{ mongodb_tls_mode }}
    certificateKeyFile: {{ mongodb_tls_cert_key_file }}
    CAFile: {{ mongodb_tls_ca_file }}
    disabledProtocols: {{ mongodb_tls_disabled_protocols }}

# STIG: enable role-based access control (authentication/authorization)
security:
  authorization: {{ mongodb_authorization }}
  javascriptEnabled: {{ mongodb_javascript_enabled | string | lower }}

# STIG: enable audit logging of security-relevant events
auditLog:
  destination: {{ mongodb_audit_destination }}
  format: {{ mongodb_audit_format }}
  path: {{ mongodb_audit_path }}

setParameter:
  authenticationMechanisms: {{ mongodb_auth_mechanisms }}
