# Example inventory for the IBM DB2 V10.5 STIG role.
# The role runs ON the DB2 server host and becomes the instance owner.
[db2_servers]
db2-prod-01 ansible_host=10.0.0.91

[db2_servers:vars]
ansible_user=ansible
ansible_become=true
ansible_become_method=sudo
db2_instance_owner=db2inst1
db2_database=PRODDB
# Provide via Ansible Vault for SQL GRANT/REVOKE + audit:
# db2_connect_user=db2admin
# db2_connect_password="{{ vault_db2_admin_password }}"
