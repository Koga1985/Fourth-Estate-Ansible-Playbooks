# IBM DB2 STIG Inventory Example
# Copy this file to 'inventory' and customize for your environment:
#   cp inventory.example inventory
#
# Usage:
#   ansible-playbook roles/db2_stig/playbooks/run.yml -i inventory

[db2_servers]
db2-prod-01.example.com ansible_host=192.168.1.85
db2-prod-02.example.com ansible_host=192.168.1.86

[db2_servers:vars]
ansible_user=ansible
ansible_become=true
ansible_python_interpreter=/usr/bin/python3
# DB2 instance owner used for db2 CLI commands (see roles/db2_stig/defaults)
db2_instance_owner=db2inst1
