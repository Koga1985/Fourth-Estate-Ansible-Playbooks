# Cisco ACI Inventory Example
# Copy this file to your inventory directory and customize
# All ACI operations are performed via the APIC REST API from localhost

# =========================================
# Cisco APIC (Application Policy Infrastructure Controller)
# =========================================
[aci_apic]
apic-01 ansible_host=192.168.1.10
apic-02 ansible_host=192.168.1.11
apic-03 ansible_host=192.168.1.12

# =========================================
# ACI Spine Switches
# =========================================
[aci_spine]
spine-01 ansible_host=192.168.1.20 aci_node_id=101
spine-02 ansible_host=192.168.1.21 aci_node_id=102

# =========================================
# ACI Leaf Switches
# =========================================
[aci_leaf]
leaf-01 ansible_host=192.168.1.30 aci_node_id=201
leaf-02 ansible_host=192.168.1.31 aci_node_id=202
leaf-03 ansible_host=192.168.1.32 aci_node_id=203
leaf-04 ansible_host=192.168.1.33 aci_node_id=204

# =========================================
# ACI Fabric Groupings
# =========================================
[aci_fabric:children]
aci_apic
aci_spine
aci_leaf

# =========================================
# Localhost for API Operations
# =========================================
[localhost]
localhost ansible_connection=local ansible_python_interpreter=/usr/bin/python3

# =========================================
# APIC Variables
# =========================================
[aci_apic:vars]
# APIC API Configuration (used by cisco.aci modules)
aci_host={{ ansible_host }}
aci_username={{ vault_aci_username }}
aci_password={{ vault_aci_password }}
aci_validate_certs=true
aci_use_ssl=true
aci_use_proxy=false

[aci_fabric:vars]
# Primary APIC for API calls
aci_apic_hostname={{ vault_aci_apic_hostname }}
aci_apic_username={{ vault_aci_username }}
aci_apic_password={{ vault_aci_password }}

# =========================================
# Fabric Configuration Variables
# =========================================
[aci_apic:vars]
# ACI Fabric Name
aci_fabric_name=FourthEstate-ACI

# Pod configuration
aci_pod_id=1

# Infrastructure VLAN
aci_infra_vlan=4093

# ACI Version
aci_version=5.2

# =========================================
# Tenant Configuration Variables
# =========================================
[localhost:vars]
# APIC connection for API-based tasks
aci_host={{ vault_aci_apic_hostname }}
aci_username={{ vault_aci_username }}
aci_password={{ vault_aci_password }}
aci_validate_certs=true
aci_use_ssl=true

# Deployment control
apply_changes=false
artifacts_dir=/tmp/aci-artifacts

# Organization
aci_org_name=FourthEstate
aci_org_description=Fourth Estate Organization - Cisco ACI

# DNS Servers (DoD approved)
aci_dns_servers=["8.8.8.8","8.8.4.4"]

# NTP Servers (DoD approved)
aci_ntp_servers=["time.nist.gov","time-a-g.nist.gov"]

# =========================================
# Security Variables
# =========================================
[localhost:vars]
# STIG hardening
stig_cat1_enabled=true
stig_cat2_enabled=true
stig_cat3_enabled=true

# Authentication
aci_auth_domain={{ vault_aci_auth_domain }}
aci_ldap_server={{ vault_aci_ldap_server }}
aci_ldap_bind_dn={{ vault_aci_ldap_bind_dn }}
aci_ldap_bind_password={{ vault_aci_ldap_bind_password }}
aci_radius_server={{ vault_aci_radius_server }}
aci_radius_key={{ vault_aci_radius_key }}
aci_tacacs_server={{ vault_aci_tacacs_server }}
aci_tacacs_key={{ vault_aci_tacacs_key }}

# Session management
aci_session_timeout=600
aci_idle_timeout=300

# Minimum password length (DoD STIG requirement)
aci_password_min_length=15

# =========================================
# Monitoring Variables
# =========================================
[localhost:vars]
# SNMP
aci_snmp_community={{ vault_aci_snmp_community }}
aci_snmp_trap_destination=monitor.example.com
aci_snmp_version=v3

# Syslog
aci_syslog_destination=siem.example.com
aci_syslog_port=514
aci_syslog_severity=warnings

# Call Home
aci_callhome_enabled=true
aci_callhome_email={{ vault_aci_callhome_email }}
aci_callhome_smtp_server=smtp.example.com
