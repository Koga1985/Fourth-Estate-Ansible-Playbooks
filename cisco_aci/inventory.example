# Cisco ACI Inventory Example
# Copy this file to your inventory directory and customize for your environment.
#
# ACI is API-driven: all Ansible modules communicate directly with the APIC REST API.
# The spine/leaf groups are informational — actual configuration is pushed via [localhost].
#
# Usage:
#   cp inventory.example inventory
#   # Edit IP addresses, node IDs, and vault references below
#   ansible-vault create group_vars/all/vault.yml  # store passwords here
#   ansible-playbook -i inventory site.yml --ask-vault-pass

# =========================================
# Cisco APIC (Application Policy Infrastructure Controller)
# Typically deployed as a 3-node cluster for redundancy.
# =========================================
[aci_apic]
apic-01 ansible_host=192.168.1.10    # Primary APIC
apic-02 ansible_host=192.168.1.11    # Secondary APIC
apic-03 ansible_host=192.168.1.12    # Tertiary APIC

# =========================================
# ACI Spine Switches
# Node IDs: Spines are typically 101-199.
# These are registered to the fabric during aci_fabric_deploy.
# =========================================
[aci_spine]
spine-01 ansible_host=192.168.1.20 aci_node_id=101
spine-02 ansible_host=192.168.1.21 aci_node_id=102

# =========================================
# ACI Leaf Switches
# Node IDs: Leaves are typically 201-299.
# Add one entry per leaf. aci_node_id must match the node's serial-registered ID.
# =========================================
[aci_leaf]
leaf-01 ansible_host=192.168.1.30 aci_node_id=201
leaf-02 ansible_host=192.168.1.31 aci_node_id=202
leaf-03 ansible_host=192.168.1.32 aci_node_id=203
leaf-04 ansible_host=192.168.1.33 aci_node_id=204

# =========================================
# ACI Fabric Groupings
# Used for group_vars and playbook targeting.
# =========================================
[aci_fabric:children]
aci_apic
aci_spine
aci_leaf

# =========================================
# Localhost for API Operations
# All cisco.aci module calls run from localhost against the APIC REST API.
# Do not change ansible_connection or python interpreter unless your environment requires it.
# =========================================
[localhost]
localhost ansible_connection=local ansible_python_interpreter=/usr/bin/python3

# =========================================
# APIC Connection Variables
# These are used by cisco.aci modules on each APIC host.
# aci_validate_certs: set to false in lab environments with self-signed certs.
# =========================================
[aci_apic:vars]
aci_host={{ ansible_host }}
aci_username={{ vault_aci_username }}
aci_password={{ vault_aci_password }}
aci_validate_certs=true           # Set to false for lab/self-signed certs
aci_use_ssl=true
aci_use_proxy=false

[aci_fabric:vars]
# Primary APIC for API calls (used when targeting the fabric group)
aci_apic_hostname={{ vault_aci_apic_hostname }}
aci_apic_username={{ vault_aci_username }}
aci_apic_password={{ vault_aci_password }}

# =========================================
# Fabric Configuration Variables
# =========================================
[aci_apic:vars]
# Logical fabric name — appears in APIC UI and artifact reports
aci_fabric_name=FourthEstate-ACI

# Pod ID — almost always 1 unless using Multi-Pod
aci_pod_id=1

# Infrastructure VLAN — ACI internal VLAN for APIC-to-switch communication
# Default is 4093; change only if this conflicts with your environment
aci_infra_vlan=4093

# ACI version running on APICs — used for feature compatibility checks
aci_version=5.2

# =========================================
# Localhost Variables
# All tenant, network, security, and monitoring configuration targets localhost
# and communicates with the APIC via REST API.
# =========================================
[localhost:vars]
# APIC connection (points to primary APIC)
aci_host={{ vault_aci_apic_hostname }}
aci_username={{ vault_aci_username }}
aci_password={{ vault_aci_password }}
aci_validate_certs=true

# Deployment control:
#   apply_changes=false → dry run only, no changes written to APIC (safe default)
#   apply_changes=true  → changes are applied; set explicitly on command line
apply_changes=false
artifacts_dir=/tmp/aci-artifacts    # Directory for JSON/text report artifacts

# Organization naming — used in policy names, descriptions, and security domains
aci_org_name=FourthEstate
aci_org_description=Fourth Estate Organization - Cisco ACI

# DNS Servers — used by aci_security_hardening for APIC DNS configuration
# Replace with your organization's approved DNS servers
aci_dns_servers=["8.8.8.8","8.8.4.4"]

# NTP Servers — used by aci_security_hardening (STIG CISC-ND-001290/001420)
# Replace with DoD-approved or organization NTP servers
aci_ntp_servers=["time.nist.gov","time-a-g.nist.gov"]

# =========================================
# Security Variables (aci_security_hardening)
# Controls which STIG categories are applied.
# All default to true for full DoD STIG compliance.
# =========================================
[localhost:vars]
# STIG category toggles — disable a category to skip those controls
stig_cat1_enabled=true    # High severity (authentication, TLS) — recommended: always true
stig_cat2_enabled=true    # Medium severity (sessions, audit, SNMP)
stig_cat3_enabled=true    # Low severity (banners, NTP, system ID)

# Authentication — reference vault variables; actual values stored in vault.yml
# aci_auth_realm_type in defaults/main.yml controls whether LDAP/RADIUS/TACACS+ is used
aci_auth_domain={{ vault_aci_auth_domain }}
aci_ldap_server={{ vault_aci_ldap_server }}
aci_ldap_bind_dn={{ vault_aci_ldap_bind_dn }}
aci_ldap_bind_password={{ vault_aci_ldap_bind_password }}
aci_radius_server={{ vault_aci_radius_server }}
aci_radius_key={{ vault_aci_radius_key }}
aci_tacacs_server={{ vault_aci_tacacs_server }}
aci_tacacs_key={{ vault_aci_tacacs_key }}

# Session timeouts (seconds) — STIG CISC-ND-000390 requires ≤ 600s idle
aci_session_timeout=600   # Maximum session duration (10 minutes)
aci_idle_timeout=300      # Idle timeout before automatic logout (5 minutes)

# Password policy — STIG CISC-ND-000570 requires minimum 15 characters
aci_password_min_length=15

# =========================================
# Monitoring Variables (aci_monitoring)
# =========================================
[localhost:vars]
# SNMP — SNMPv3 is required per STIG CISC-ND-000090; v1/v2 are disabled
aci_snmp_community={{ vault_aci_snmp_community }}      # Used only for legacy queries if needed
aci_snmp_trap_destination=monitor.example.com          # Replace with your SNMP trap receiver
aci_snmp_version=v3

# Syslog — replace with your SIEM server address
aci_syslog_destination=siem.example.com
aci_syslog_port=514
aci_syslog_severity=warnings    # Options: emergencies, alerts, critical, errors, warnings, notifications, information, debugging

# Call Home — replace with your NOC email and SMTP relay
aci_callhome_enabled=true
aci_callhome_email={{ vault_aci_callhome_email }}
aci_callhome_smtp_server=smtp.example.com
