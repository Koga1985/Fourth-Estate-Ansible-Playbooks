---
# Pure Storage — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# ---- FlashArray API token (used in inventory) --------------------------------
vault_pure_fa_api_token: "CHANGE_ME"  # FlashArray API token (fa_api_token in inventory)

# ---- Active Directory / LDAP bind password ----------------------------------
vault_bind_password: "CHANGE_ME"     # AD/LDAP bind account password

# ---- FlashBlade user password -----------------------------------------------
vault_fb_user_pw: "CHANGE_ME"        # FlashBlade management user password

# ---- VASA provider password (VMware integration) ----------------------------
vault_pure_vasa_pass: "CHANGE_ME"    # VASA provider registration password
