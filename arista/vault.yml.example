---
# Arista EOS / CloudVision Portal — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ---- EOS switch credentials (used for httpapi/eAPI connection) --------------
vault_arista_username: "ansible"
vault_arista_password: "CHANGE_ME"

# ---- CloudVision Portal (CVP) credentials -----------------------------------
# Required only if using the arista_cvp_inventory_model role
vault_cvp_username: "ansible"
vault_cvp_password: "CHANGE_ME"
