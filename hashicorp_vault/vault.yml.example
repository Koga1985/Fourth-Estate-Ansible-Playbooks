---
# HashiCorp Vault — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# NOTE: These variables configure the HashiCorp Vault SERVER deployment.
# They are stored in Ansible Vault (ansible-vault) to protect the secrets
# needed to bootstrap and configure HashiCorp Vault itself.

# ---- Vault cluster admin credentials ----------------------------------------
vault_admin_token: "CHANGE_ME"             # Initial root/admin token (rotate after setup)
vault_unseal_key_1: "CHANGE_ME"            # Unseal key share 1 (if manual unseal)
vault_unseal_key_2: "CHANGE_ME"            # Unseal key share 2
vault_unseal_key_3: "CHANGE_ME"            # Unseal key share 3

# ---- Auto-unseal: AWS KMS (set if vault_auto_unseal: awskms) ----------------
vault_awskms_region: "us-gov-west-1"
vault_awskms_kms_key_id: "CHANGE_ME"       # KMS key ID or ARN
# vault_awskms_endpoint: ""                # Optional custom endpoint

# ---- Auto-unseal: Azure Key Vault (set if vault_auto_unseal: azurekeyvault) -
vault_azure_tenant_id: "CHANGE_ME"
vault_azure_client_id: "CHANGE_ME"
vault_azure_client_secret: "CHANGE_ME"
vault_azure_vault_name: "CHANGE_ME"
vault_azure_key_name: "CHANGE_ME"

# ---- LDAP authentication backend --------------------------------------------
vault_ldap_bind_dn: "cn=svc-vault,ou=service,dc=example,dc=com"
vault_ldap_bind_password: "CHANGE_ME"
