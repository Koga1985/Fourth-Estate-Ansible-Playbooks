# Example inventory for the Dynatrace OneAgent role.
[dynatrace_hosts]
app-linux-01 ansible_host=10.0.0.71
app-win-01   ansible_host=10.0.0.72 ansible_connection=winrm ansible_port=5986

[dynatrace_hosts:vars]
ansible_user=ansible
