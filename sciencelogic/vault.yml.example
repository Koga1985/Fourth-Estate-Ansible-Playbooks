---
# ScienceLogic SL1 — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ===========================================================================
# Required — minimum set needed to connect to SL1
# ===========================================================================
vault_sl1_admin_password: "CHANGE_ME"      # SL1 web UI admin password
vault_sl1_api_user: "ansible"              # SL1 API service account username
vault_sl1_api_password: "CHANGE_ME"        # SL1 API service account password
vault_sl1_api_token: "CHANGE_ME"           # API token (alternative to user/pass)

# ===========================================================================
# Database credentials
# ===========================================================================
vault_sl1_db_root_password: "CHANGE_ME"            # MariaDB root password
vault_sl1_db_replication_password: "CHANGE_ME"     # DB replication user password

# ===========================================================================
# License key
# ===========================================================================
vault_sl1_license_key: "CHANGE_ME"

# ===========================================================================
# Operator and monitoring accounts
# ===========================================================================
vault_admin_password: "CHANGE_ME"          # OS-level admin password
vault_operator_password: "CHANGE_ME"       # SL1 operator account password

# ===========================================================================
# LDAP / Active Directory integration
# ===========================================================================
vault_ldap_bind_password: "CHANGE_ME"

# ===========================================================================
# SNMP
# ===========================================================================
vault_snmp_community: "CHANGE_ME"

# ===========================================================================
# SMTP notifications
# ===========================================================================
vault_smtp_username: "alerts@example.com"
vault_smtp_password: "CHANGE_ME"

# ===========================================================================
# External integrations
# ===========================================================================
vault_backup_credentials: "CHANGE_ME"     # Backup destination credentials
