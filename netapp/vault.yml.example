---
# NetApp ONTAP — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ---- Cluster management credentials -----------------------------------------
vault_netapp_cluster_hostname: "ontap-cluster01.example.com"
vault_netapp_cluster_username: "ansible"
vault_netapp_cluster_password: "CHANGE_ME"

# ---- Disaster recovery cluster credentials ----------------------------------
vault_netapp_dr_password: "CHANGE_ME"       # DR/SnapMirror destination cluster password

# ---- Active Directory / CIFS credentials ------------------------------------
vault_netapp_cifs_admin_user: "CHANGE_ME"   # AD domain join user (for CIFS/SMB)
vault_netapp_cifs_admin_password: "CHANGE_ME"

# ---- LDAP bind credentials --------------------------------------------------
vault_netapp_ldap_bind_password: "CHANGE_ME"

# ---- SNMP community string --------------------------------------------------
vault_netapp_snmp_community: "CHANGE_ME"

# ---- SnapMirror cluster peer passphrase ------------------------------------
vault_cluster_peer_passphrase: "CHANGE_ME"  # Required for cluster peering

# ---- Feature licenses (optional — leave empty if already applied) -----------
vault_netapp_license_nfs: ""
vault_netapp_license_cifs: ""
vault_netapp_license_iscsi: ""
vault_netapp_license_fcp: ""
vault_netapp_license_flexclone: ""
vault_netapp_license_snapmirror: ""
vault_netapp_license_snapvault: ""
vault_netapp_license_snaprestore: ""
vault_netapp_license_nve: ""
