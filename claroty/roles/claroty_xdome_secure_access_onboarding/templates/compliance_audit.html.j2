<!DOCTYPE html>
<html lang="en">
<head><meta charset="utf-8"><title>Compliance Audit</title></head>
<body>
<h1>Compliance Audit</h1>
<p>Generated: {{ ansible_date_time.iso8601 | default('') }} on {{ inventory_hostname }}</p>
<p>Classification: {{ classification | default('CUI') }}</p>
<table border="1" cellpadding="4">
  <thead><tr><th>Item</th><th>Detail</th></tr></thead>
  <tbody>
  {% for row in report_items | default([]) %}
    <tr><td>{{ row.name | default(row) }}</td><td>{{ row.detail | default('') }}</td></tr>
  {% endfor %}
  </tbody>
</table>
</body>
</html>
