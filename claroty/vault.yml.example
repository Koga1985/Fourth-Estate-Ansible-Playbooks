---
# Claroty OT Security — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# Where to find these values:
#   API token:  Claroty console > Settings > Integrations > API tokens

# ---- Required ---------------------------------------------------------------
vault_claroty_api_token: "CHANGE_ME"   # REST API token
vault_claroty_siem_token: "CHANGE_ME"  # SIEM integration token (if using syslog/SIEM push)
