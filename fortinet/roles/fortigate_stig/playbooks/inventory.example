# Example inventory for the FortiGate Firewall STIG role.
# FortiOS is managed over httpapi from the control node.
[fortigates]
fgt-01 ansible_host=10.0.0.45

[fortigates:vars]
ansible_connection=httpapi
ansible_network_os=fortinet.fortios.fortios
ansible_httpapi_use_ssl=true
ansible_httpapi_validate_certs=true
ansible_httpapi_port=443
ansible_user=admin
# Prefer an API token (vaulted):
# ansible_httpapi_key="{{ vault_fgt_api_token }}"
# ansible_password="{{ vault_fgt_password }}"
