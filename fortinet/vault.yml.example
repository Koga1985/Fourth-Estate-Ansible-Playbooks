---
# Fortinet FortiGate — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ---- FortiGate REST API tokens (used in inventory.example httpapi connection)
vault_fortios_token: "CHANGE_ME"          # FortiGate REST API token (fortios_access_token)
vault_fmg_token: "CHANGE_ME"             # FortiManager REST API token (fortimanager_access_token)

# ---- FortiGate admin credentials (alternative to API token) ----------------
vault_fortigate_username: "ansible"
vault_fortigate_password: "CHANGE_ME"

# ---- Additional admin accounts (for RBAC roles) ----------------------------
vault_admin_username: "admin"
vault_admin_password: "CHANGE_ME"
vault_readonly_username: "readonly"
vault_readonly_password: "CHANGE_ME"
vault_security_username: "security_admin"
vault_security_password: "CHANGE_ME"

# ---- SNMPv3 authentication --------------------------------------------------
vault_snmp_user: "snmpv3_user"
vault_snmp_auth_password: "CHANGE_ME"     # min 8 chars
vault_snmp_priv_password: "CHANGE_ME"
vault_snmp_community: "CHANGE_ME"         # SNMPv2c community string (if using v2c)

# ---- Certificate management -------------------------------------------------
vault_cert_password: "CHANGE_ME"          # Passphrase for importing certificates

# ---- FortiGuard subscription ------------------------------------------------
vault_fortiguard_account_id: "CHANGE_ME"  # FortiGuard account ID for licensing
