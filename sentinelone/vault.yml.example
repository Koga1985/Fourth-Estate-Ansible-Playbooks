---
# SentinelOne — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# Where to find these values:
#   Site token:  SentinelOne console > Settings > Sites > click site > Site Token
#   API token:   SentinelOne console > Settings > Users > click user > API Token

# ---- Required ---------------------------------------------------------------
vault_s1_site_token: "CHANGE_ME"   # per-site registration token
vault_s1_api_token: "CHANGE_ME"    # used for api install method and management tasks
