# Example Ansible Inventory for SentinelOne EDR
#
# Copy this file to 'inventory' and customize for your environment:
#   cp inventory.example inventory
#
# Usage:
#   ansible-playbook -i inventory site.yml --ask-vault-pass

# -----------------------------------------------------------------------
# [s1_targets] — hosts that will receive the SentinelOne agent
# -----------------------------------------------------------------------
[s1_targets]
# Linux servers
linux-prod-01.example.com ansible_host=192.168.1.10
linux-prod-02.example.com ansible_host=192.168.1.11

# Windows servers (WinRM connection)
# win-prod-01.example.com ansible_host=192.168.1.20

# Development hosts
# linux-dev-01.example.com ansible_host=192.168.2.10

[linux_hosts]
linux-prod-01.example.com
linux-prod-02.example.com

[windows_hosts]
# win-prod-01.example.com

# -----------------------------------------------------------------------
# Group variables — non-sensitive configuration
# -----------------------------------------------------------------------
[s1_targets:vars]
ansible_user=ansible
ansible_become=true
ansible_become_method=sudo
ansible_python_interpreter=/usr/bin/python3

# SentinelOne management console URL
# US GovCloud: https://usgoveast1.sentinelone.net
# US Commercial: https://usea1.sentinelone.net
s1_console_url=https://usgoveast1.sentinelone.net

# Agent version — use "latest" or specify e.g. "23.4.0"
s1_agent_version=latest

# Agent group in SentinelOne console
s1_group_name=Default

# Tags applied to agents (comma-separated)
s1_tags=Fourth-Estate,Managed-by-Ansible,Production

# Installation method: api (downloads from console), local (use local file)
s1_install_method=api

# Set to true for networks with no direct internet access
s1_air_gapped=false
# s1_agent_download_url=https://internal-repo.example.com/sentinelone

[windows_hosts:vars]
ansible_connection=winrm
ansible_winrm_transport=kerberos
ansible_winrm_server_cert_validation=validate

# -----------------------------------------------------------------------
# Credentials — store in vault.yml, NOT here
# See: ansible-vault create group_vars/all/vault.yml
# Required vault variables:
#   vault_s1_site_token  — Site token from SentinelOne console (Settings > Sites)
#   vault_s1_api_token   — API token from SentinelOne console (Settings > Users)
# -----------------------------------------------------------------------
