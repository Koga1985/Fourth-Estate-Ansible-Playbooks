---
# ServiceNow CMDB — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# Where to find these values:
#   ServiceNow instance URL: from your ServiceNow administrator
#   API credentials: ServiceNow > User Administration > Users > create service account

# ---- ServiceNow API credentials ---------------------------------------------
vault_servicenow_username: "ansible_svc"
vault_servicenow_password: "CHANGE_ME"
vault_servicenow_instance: "CHANGE_ME"  # e.g. "dev12345" (subdomain of service-now.com)
