---
# Illumio Zero-Trust Segmentation — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# Where to find these values:
#   PCE admin credentials: Illumio PCE web console > Users

# ---- PCE API credentials (used in inventory) --------------------------------
vault_illumio_api_user: "CHANGE_ME"                 # PCE API user (e.g. api_XXXXX)
vault_illumio_api_key: "CHANGE_ME"                  # PCE API key (secret key)

# ---- PCE credentials --------------------------------------------------------
vault_illumio_pce_admin_password: "CHANGE_ME"       # PCE web console admin password
vault_illumio_pce_database_password: "CHANGE_ME"    # Internal PostgreSQL database password
vault_illumio_pce_superuser_password: "CHANGE_ME"   # OS-level superuser for PCE services
