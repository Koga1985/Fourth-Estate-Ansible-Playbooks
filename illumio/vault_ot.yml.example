---
# =============================================================================
# Illumio OT ACL Deployment — Vault Variables Example
# =============================================================================
# Copy this file to:  illumio/group_vars/all/vault_ot.yml
# Then encrypt it:    ansible-vault encrypt illumio/group_vars/all/vault_ot.yml
#
# Run playbooks with: --ask-vault-pass
#   OR store the vault password in a file and use --vault-password-file.
#
# NEVER commit the unencrypted vault file to version control.
# Only this example file (with placeholder values) is safe to commit.
# =============================================================================

# ── Illumio PCE API credentials ───────────────────────────────────────────────
# Found in: PCE web console → Users → API Keys
vault_illumio_api_user: "CHANGE_ME"           # e.g. api_XXXXXXXXXXXX
vault_illumio_api_key: "CHANGE_ME"            # PCE API secret key

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Used by the alert task to send notifications to the network team.
vault_smtp_host: "CHANGE_ME"                  # e.g. smtp.example.com
vault_smtp_port: 25                           # or 587 for TLS
vault_smtp_username: "CHANGE_ME"              # leave blank if relay requires no auth
vault_smtp_password: "CHANGE_ME"              # leave blank if relay requires no auth
vault_network_team_email: "CHANGE_ME"         # e.g. network-team@example.com

# ── Webhook (optional) ────────────────────────────────────────────────────────
# Set ot_webhook_enabled=true in inventory_ot to activate.
# Supports any webhook endpoint: Slack, MS Teams, PagerDuty, SOAR, etc.
vault_ot_webhook_url: "CHANGE_ME"             # e.g. https://hooks.slack.com/services/...
vault_ot_webhook_token: "CHANGE_ME"           # Bearer token if required (leave blank if not)

# ── Syslog (optional) ────────────────────────────────────────────────────────
# Set ot_syslog_enabled=true in inventory_ot to activate.
vault_syslog_server: "CHANGE_ME"              # e.g. 10.0.0.50
