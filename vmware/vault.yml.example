---
# VMware vSphere / NSX-T — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ---- ESXi host credentials --------------------------------------------------
vault_esxi_root_password: "CHANGE_ME"      # ESXi root password

# ---- vCenter service accounts -----------------------------------------------
vault_opsadmin_pwd: "CHANGE_ME"            # vCenter operations admin password
vault_ro_pwd: "CHANGE_ME"                  # vCenter read-only service account password
vault_win_admin_pwd: "CHANGE_ME"           # Windows admin password (for Windows-based vCenter)

# ---- Active Directory domain join -------------------------------------------
vault_join_pwd: "CHANGE_ME"               # AD domain join account password

# ---- LDAP / directory services ----------------------------------------------
vault_ldap_bind_password: "CHANGE_ME"     # LDAP bind account password
