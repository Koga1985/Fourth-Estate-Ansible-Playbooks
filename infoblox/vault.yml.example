---
# Infoblox DNS/DHCP — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ---- Infoblox API credentials (primary admin) --------------------------------
vault_infoblox_password: "CHANGE_ME"           # Admin API user password

# ---- Specialized service accounts -------------------------------------------
vault_infoblox_readonly_password: "CHANGE_ME"  # Read-only monitoring account
vault_infoblox_netops_password: "CHANGE_ME"    # Network operations account
vault_infoblox_security_password: "CHANGE_ME"  # Security/audit account

# ---- SMTP relay (for alerts) ------------------------------------------------
vault_infoblox_smtp_password: "CHANGE_ME"      # SMTP relay authentication password

# ---- SNMPv2c community string -----------------------------------------------
vault_infoblox_snmp_community: "CHANGE_ME"     # SNMP read community string

# ---- Backup SCP/SFTP credentials --------------------------------------------
vault_infoblox_backup_password: "CHANGE_ME"    # Backup destination password
