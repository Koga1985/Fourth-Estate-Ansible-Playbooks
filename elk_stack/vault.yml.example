---
# ELK Stack — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ---- Elasticsearch built-in user passwords ----------------------------------
vault_elasticsearch_elastic_password: "CHANGE_ME"   # 'elastic' superuser
vault_elasticsearch_kibana_password: "CHANGE_ME"    # 'kibana_system' user
vault_elasticsearch_logstash_password: "CHANGE_ME"  # 'logstash_system' / pipeline user

# ---- Kibana encryption key (32+ random characters) -------------------------
vault_kibana_encryption_key: "CHANGE_ME_USE_32_OR_MORE_RANDOM_CHARS"
