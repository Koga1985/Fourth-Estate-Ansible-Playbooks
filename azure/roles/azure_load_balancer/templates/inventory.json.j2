{
  "role": "{{ role_name | default('azure') }}",
  "generated": "{{ ansible_date_time.iso8601 | default('') }}",
  "host": "{{ inventory_hostname }}",
  "cloud_environment": "{{ azure_cloud_environment | default('') }}",
  "subscription_id": "{{ azure_subscription_id | default('') }}",
  "resource_group": "{{ azure_resource_group | default('') }}",
  "location": "{{ azure_location | default('') }}",
  "classification": "{{ azure_classification | default('SECRET') }}",
  "compliance": "FedRAMP-High"
}
