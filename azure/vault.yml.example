---
# Microsoft Azure — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# NOTE: Azure authentication uses a Service Principal. Set the following
# environment variables before running (or store them in vault below):
#
#   export AZURE_SUBSCRIPTION_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
#   export AZURE_CLIENT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
#   export AZURE_SECRET="CHANGE_ME"
#   export AZURE_TENANT="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
#
# Alternatively store in vault:

# ---- Azure Service Principal credentials ------------------------------------
vault_azure_subscription_id: "CHANGE_ME"   # Azure subscription GUID
vault_azure_client_id: "CHANGE_ME"         # Service principal application (client) ID
vault_azure_client_secret: "CHANGE_ME"     # Service principal client secret
vault_azure_tenant_id: "CHANGE_ME"         # Azure AD tenant ID
