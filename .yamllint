# yamllint configuration for Fourth Estate Ansible Playbooks
#
# Philosophy: enforce the rules that catch *production-breaking* mistakes
# (YAML that won't parse, duplicate keys that silently override) while
# disabling purely cosmetic rules so the gate stays signal, not noise.
#
# Run locally:  yamllint -c .yamllint .
---
extends: default

rules:
  # --- Hard correctness rules (kept enabled) ---
  key-duplicates: enable        # duplicate keys silently override -> wrong behavior
  # NOTE: YAML *syntax* errors are always reported by yamllint regardless of
  # rule config; they are the primary thing this gate guards against.

  # --- Cosmetic rules (disabled to avoid noise on a large existing codebase) ---
  line-length: disable
  comments: disable
  comments-indentation: disable
  document-start: disable
  truthy: disable
  indentation: disable
  trailing-spaces: disable
  empty-lines: disable
  brackets: disable
  braces: disable
  colons: disable
  hyphens: disable
  commas: disable
  new-line-at-end-of-file: disable
  octal-values: disable
  empty-values: disable

ignore: |
  .git/
  .github/
  .vscode/
