---
# VAST Data Storage — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# A pre-populated example is also available at: vars/vault.yml.example

# ---- Active Directory integration -------------------------------------------
vault_ad_server: "dc01.example.com"
vault_ad_domain: "example.com"
vault_ad_username: "svc-vast-ansible"
vault_ad_password: "CHANGE_ME"
vault_ad_ou: "OU=ServiceAccounts,DC=example,DC=com"

# ---- Kerberos / NFS Kerberos ------------------------------------------------
vault_kerberos_realm: "EXAMPLE.COM"
vault_kerberos_kdc: "dc01.example.com"

# ---- LDAP integration -------------------------------------------------------
vault_ldap_server: "ldap.example.com"
vault_ldap_base_dn: "dc=example,dc=com"
vault_ldap_bind_dn: "cn=svc-vast,ou=service,dc=example,dc=com"
vault_ldap_bind_password: "CHANGE_ME"

# ---- SIEM / syslog integration ----------------------------------------------
vault_siem_server: "siem.example.com"

# ---- Grafana integration (for monitoring role) ------------------------------
vault_grafana_url: "https://grafana.example.com"
vault_grafana_api_key: "CHANGE_ME"

# ---- SMTP (for alerts) ------------------------------------------------------
vault_smtp_server: "smtp.example.com"
vault_smtp_username: "alerts@example.com"
vault_smtp_password: "CHANGE_ME"

# ---- SNMP trap destinations -------------------------------------------------
vault_snmp_trap_server_primary: "snmp-mgr-01.example.com"
vault_snmp_trap_server_secondary: "snmp-mgr-02.example.com"

# ---- Backup destination (SCP/SFTP) ------------------------------------------
vault_backup_destination: "backup@backup-server.example.com:/backups/vast"
