{{ ansible_managed | comment }}
# DISA Web Server SRG hardening - {{ stig_benchmark }} {{ stig_version }}
# Managed by apache_web_server_srg. Do not edit by hand.

# SRG-APP-000516-WSR-000174 - suppress product/version disclosure
ServerTokens {{ apache_server_tokens }}
ServerSignature {{ apache_server_signature }}

# SRG-APP-000141-WSR-000081 - disable HTTP TRACE method
TraceEnable {{ apache_trace_enable }}

# SRG-APP-000001-WSR-000001 - connection/session limits
Timeout {{ apache_timeout }}
KeepAlive {{ apache_keepalive }}
KeepAliveTimeout {{ apache_keepalive_timeout }}
MaxKeepAliveRequests {{ apache_max_keepalive_requests }}

# SRG-APP-000211-WSR-000031 - disable directory browsing globally
<Directory />
    AllowOverride None
    Options None
    Require all denied
</Directory>

# SRG-APP-000439-WSR-000156 - TLS protocol and cipher hardening
<IfModule mod_ssl.c>
    SSLProtocol {{ apache_ssl_protocol }}
    SSLCipherSuite {{ apache_ssl_cipher_suite }}
    SSLHonorCipherOrder {{ apache_ssl_honor_cipher_order }}
</IfModule>

# SRG-APP-000358-WSR-000063 - logging
LogLevel {{ apache_log_level }}
