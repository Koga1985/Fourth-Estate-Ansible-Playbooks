# Application & Web Server SRG Inventory Example
# Copy this file to 'inventory' and customize for your environment:
#   cp inventory.example inventory
#
# Usage:
#   ansible-playbook roles/apache_web_server_srg/playbooks/run.yml -i inventory
#   ansible-playbook roles/tomcat_app_server_srg/playbooks/run.yml -i inventory

# --- Apache HTTP Server hosts (Web Server SRG) ---
[web_servers]
web-01.example.com ansible_host=192.168.1.60
web-02.example.com ansible_host=192.168.1.61

# --- Apache Tomcat hosts (Application Server SRG) ---
[app_servers]
app-01.example.com ansible_host=192.168.1.70
app-02.example.com ansible_host=192.168.1.71

[web_servers:vars]
ansible_user=ansible
ansible_become=true
ansible_python_interpreter=/usr/bin/python3
# Path defaults assume RHEL/EL (/etc/httpd). For Debian/Ubuntu set the
# apache_* path variables (see roles/apache_web_server_srg/defaults/main.yml).

[app_servers:vars]
ansible_user=ansible
ansible_become=true
ansible_python_interpreter=/usr/bin/python3
