# Example inventory for the Windows Server 2022 STIG role.
# Use Ansible Vault for credentials; WinRM/PSRP must be reachable.
[windows_2022]
member-01 ansible_host=10.0.0.101
dc-01     ansible_host=10.0.0.102 win_is_domain_controller=true win_is_dns_server=true

[windows_2022:vars]
ansible_connection=winrm
ansible_winrm_transport=ntlm
ansible_port=5986
ansible_winrm_server_cert_validation=validate
ansible_user=svc_ansible
# ansible_password="{{ vault_win_password }}"
