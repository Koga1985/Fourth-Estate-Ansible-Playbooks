---
# Windows Server — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# Windows roles connect via WinRM. The ansible_user and ansible_password
# are the primary required credentials.

# ---- WinRM connection credentials -------------------------------------------
vault_ansible_user: "ansible"           # Local or domain account with admin rights
vault_ansible_password: "CHANGE_ME"     # Account password

# ---- Domain join credentials (required for AD domain join role) -------------
vault_domain_admin_user: "Administrator@example.com"
vault_domain_admin_password: "CHANGE_ME"

# ---- Local administrator password -------------------------------------------
vault_local_admin_password: "CHANGE_ME"
