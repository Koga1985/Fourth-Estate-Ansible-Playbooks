# Managed by Ansible (splunk_indexer_cluster) - multisite cluster manager
[general]
serverName = {{ inventory_hostname }}
pass4SymmKey = {{ splunk_pass4symmkey | default(splunk_admin_password) }}

[clustering]
mode = manager
multisite = true
available_sites = {{ splunk_available_sites | default(['site1']) | join(',') }}
site_replication_factor = {{ splunk_site_replication_factor | default('origin:2,total:3') }}
site_search_factor = {{ splunk_site_search_factor | default('origin:1,total:2') }}
cluster_label = {{ splunk_cluster_label | default('splunk_cluster') }}
