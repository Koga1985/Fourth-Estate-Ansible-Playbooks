# Example inventory for the Splunk Enterprise STIG role.
# Runs on the Splunk host and edits $SPLUNK_HOME/etc/system/local/*.conf.
[splunk_servers]
splunk-01 ansible_host=10.0.0.60

[splunk_servers:vars]
ansible_user=ansible
ansible_become=true
ansible_become_method=sudo
splunk_home=/opt/splunk
splunk_os_user=splunk
