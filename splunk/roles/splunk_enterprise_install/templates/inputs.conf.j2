# Managed by Ansible (splunk_enterprise_install)
[default]
host = {{ inventory_hostname }}

[splunktcp://{{ splunk_receiving_port | default(9997) }}]
disabled = {{ (not (splunk_enable_receiving | default(true))) | lower }}
{% for inp in splunk_inputs | default([]) %}

[{{ inp.stanza }}]
{% for k, v in (inp.settings | default({})).items() %}
{{ k }} = {{ v }}
{% endfor %}
{% endfor %}
