# Managed by Ansible (splunk_enterprise_install)
{% if (splunk_forward_servers | default([])) | length > 0 %}
[tcpout]
defaultGroup = primary_indexers
[tcpout:primary_indexers]
server = {{ splunk_forward_servers | join(',') }}
{% if splunk_indexer_discovery | default(false) %}
indexerDiscovery = cluster_master
{% endif %}
{% else %}
# No forward servers configured (set splunk_forward_servers to enable forwarding)
{% endif %}
