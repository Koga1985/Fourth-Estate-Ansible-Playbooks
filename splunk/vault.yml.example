---
# Splunk Enterprise — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ===========================================================================
# Required — minimum set needed to install Splunk
# ===========================================================================
vault_splunk_admin_password: "CHANGE_ME"    # Splunk admin UI password (min 15 chars)

# ===========================================================================
# TLS certificates (required if splunk_use_default_tls_certs: false)
# ===========================================================================
# Paths on the Ansible control host to certificate files to deploy:
# vault_splunk_server_cert: "/path/to/splunk-server.pem"
# vault_splunk_server_key: "/path/to/splunk-server.key"
# vault_splunk_ca_cert: "/path/to/ca-chain.pem"

# ===========================================================================
# LDAP / Active Directory integration
# ===========================================================================
vault_ldap_host: "ldap.example.com"
vault_ldap_bind_dn: "cn=svc-splunk,ou=service,dc=example,dc=com"
vault_ldap_bind_password: "CHANGE_ME"
vault_ldap_user_base_dn: "ou=users,dc=example,dc=com"
vault_ldap_group_base_dn: "ou=groups,dc=example,dc=com"

# ===========================================================================
# Duo MFA (only if splunk_mfa_type: DUO)
# ===========================================================================
vault_duo_integration_key: "CHANGE_ME"
vault_duo_secret_key: "CHANGE_ME"
vault_duo_api_hostname: "api-XXXXXXXX.duosecurity.com"

# ===========================================================================
# Clustering (only if splunk_cluster_mode != none)
# ===========================================================================
vault_splunk_cluster_secret: "CHANGE_ME"          # Shared cluster security key
vault_splunk_cluster_master_uri: ""               # e.g. https://cluster-master:8089
vault_splunk_cluster_label: "production"          # Cluster label

# ===========================================================================
# Search Head Clustering (only if splunk_shc_mode: true)
# ===========================================================================
vault_splunk_shc_secret: "CHANGE_ME"
vault_splunk_shc_captain_uri: ""

# ===========================================================================
# Cloud archive / backup (only if backup role is used)
# ===========================================================================
vault_aws_access_key: "CHANGE_ME"
vault_aws_secret_key: "CHANGE_ME"
vault_backup_encryption_key: "CHANGE_ME"

# ===========================================================================
# Notification targets
# ===========================================================================
vault_siem_server: "siem.example.com"
vault_monitoring_email: "ops@example.com"
