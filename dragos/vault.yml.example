---
# Dragos OT Monitoring — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# Where to find these values:
#   API token:  Dragos platform > Settings > API Access

# ---- Required ---------------------------------------------------------------
vault_dragos_api_token: "CHANGE_ME"    # Dragos platform API token
vault_dragos_siem_token: "CHANGE_ME"   # SIEM forwarding token

# ---- Optional (only if using ServiceNow or Jira integration) ----------------
vault_servicenow_user: "CHANGE_ME"
vault_servicenow_password: "CHANGE_ME"
vault_jira_token: "CHANGE_ME"
