---
# Policy as Code — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# The policy_as_code roles run against RHEL hosts via SSH.
# Use the same SSH credentials as your rhel/ platform vault file.

vault_ansible_user: "ansible"
vault_ansible_password: "CHANGE_ME"
vault_ansible_become_password: "CHANGE_ME"
