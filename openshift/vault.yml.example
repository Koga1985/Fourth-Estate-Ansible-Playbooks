---
# Red Hat OpenShift — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# Where to find these values:
#   API token:   oc whoami -t   (after logging in with oc login)
#   LDAP bind DN/password: from your LDAP/Active Directory administrator

# ---- OpenShift API credentials ----------------------------------------------
vault_ocp_api_token: "CHANGE_ME"        # Service account token with cluster-admin

# ---- LDAP integration (required if configuring LDAP identity provider) -----
vault_ldap_bind_dn: "cn=svc-ansible,ou=service,dc=example,dc=com"
vault_ldap_bind_password: "CHANGE_ME"
