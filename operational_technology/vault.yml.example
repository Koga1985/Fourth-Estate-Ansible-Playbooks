---
# Operational Technology (OT/ICS) — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ---- Palo Alto OT firewall credentials --------------------------------------
vault_panos_username: "ansible"
vault_panos_password: "CHANGE_ME"

# ---- Check Point OT firewall credentials ------------------------------------
vault_checkpoint_username: "ansible"
vault_checkpoint_password: "CHANGE_ME"
