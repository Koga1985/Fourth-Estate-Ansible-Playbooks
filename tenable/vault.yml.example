---
# Tenable Security Center — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml

# ---- Security Center admin credentials --------------------------------------
vault_tsc_admin_password: "CHANGE_ME"       # Tenable SC web UI admin password
vault_tsc_password: "CHANGE_ME"             # API user / scan account password

# ---- Database credentials (internal SC database) ----------------------------
vault_tsc_db_password: "CHANGE_ME"          # Tenable SC PostgreSQL application password
vault_tsc_mysql_root_password: "CHANGE_ME"  # MySQL root password (if using MySQL backend)
