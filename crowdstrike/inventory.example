# Example Ansible Inventory for CrowdStrike Falcon EDR
#
# Copy this file to 'inventory' and customize for your environment:
#   cp inventory.example inventory
#
# Usage:
#   ansible-playbook -i inventory site.yml --ask-vault-pass

# -----------------------------------------------------------------------
# [falcon_targets] — hosts that will receive the Falcon sensor
# -----------------------------------------------------------------------
[falcon_targets]
# Linux servers
linux-prod-01.example.com ansible_host=192.168.1.10
linux-prod-02.example.com ansible_host=192.168.1.11

# Windows servers (WinRM connection)
# win-prod-01.example.com ansible_host=192.168.1.20

# Development hosts
# linux-dev-01.example.com ansible_host=192.168.2.10

[linux_hosts]
linux-prod-01.example.com
linux-prod-02.example.com

[windows_hosts]
# win-prod-01.example.com

# -----------------------------------------------------------------------
# Group variables — non-sensitive configuration
# -----------------------------------------------------------------------
[falcon_targets:vars]
ansible_user=ansible
ansible_become=true
ansible_become_method=sudo
ansible_python_interpreter=/usr/bin/python3

# Falcon cloud region: us-1, us-2, eu-1, us-gov-1
falcon_cloud=us-gov-1

# Sensor version — set to a specific version for stability (e.g. "7.10.0")
falcon_sensor_version=latest

# Sensor tags applied in Falcon console (comma-separated)
falcon_sensor_tags=Fourth-Estate,Managed-by-Ansible,Production

# Installation method: api (downloads from CrowdStrike), local (use local file)
falcon_install_method=api

# Set to true for networks with no direct internet access
falcon_air_gapped=false
# falcon_sensor_download_url=https://internal-repo.example.com/falcon

[windows_hosts:vars]
ansible_connection=winrm
ansible_winrm_transport=kerberos
ansible_winrm_server_cert_validation=validate

# -----------------------------------------------------------------------
# Credentials — store in vault.yml, NOT here
# See: ansible-vault create group_vars/all/vault.yml
# Required vault variables:
#   vault_falcon_cid              — Customer ID (CID) from Falcon console
#   vault_falcon_api_client_id    — OAuth2 client ID (for api install method)
#   vault_falcon_api_client_secret — OAuth2 client secret
#   vault_falcon_installation_token — Optional provisioning token
# -----------------------------------------------------------------------
