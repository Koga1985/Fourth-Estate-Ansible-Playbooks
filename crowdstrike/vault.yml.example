---
# CrowdStrike Falcon — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# Then paste and fill in the values below.
#
# Where to find these values:
#   CID:              Falcon console > Hosts > Sensor Downloads > Customer ID
#   API credentials:  Falcon console > Support > API Clients & Keys > Create new client
#                     Required scopes: Sensor Download (Read), Hosts (Read/Write)
#   Install token:    Falcon console > Hosts > Sensor Downloads > Installation Tokens

# ---- Required ---------------------------------------------------------------
vault_falcon_cid: "XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX-XX"  # 32-char hex + 2-char check
vault_falcon_api_client_id: "CHANGE_ME"
vault_falcon_api_client_secret: "CHANGE_ME"

# ---- Optional ---------------------------------------------------------------
vault_falcon_installation_token: ""   # leave empty if not using provisioning tokens
