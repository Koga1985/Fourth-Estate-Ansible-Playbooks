# Example inventory for the Cisco ISE NDM STIG role.
# Talks to ISE ERS (9060) / OpenAPI (443) from the control node.
# Enable ERS in ISE: Administration > System > Settings > ERS Settings.
[ise]
ise-ppan ansible_host=ise.example.mil

[ise:vars]
ansible_connection=local
ise_host=ise.example.mil
ise_username=ersadmin
# ise_password="{{ vault_ise_ers_password }}"
ise_validate_certs=true
