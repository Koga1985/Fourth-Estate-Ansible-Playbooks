# Example inventory for the Cisco ASA STIG role.
# Copy to `inventory` and edit. Store credentials in Ansible Vault.
[asa_firewalls]
asa-01 ansible_host=10.0.0.71

[asa_firewalls:vars]
ansible_network_os=cisco.asa.asa
ansible_connection=ansible.netcommon.network_cli
ansible_user=svc_ansible
