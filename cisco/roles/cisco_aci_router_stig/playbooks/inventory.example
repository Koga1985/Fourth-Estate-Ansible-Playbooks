# Example inventory for the Cisco ACI Router STIG role.
# The role talks to the APIC over HTTPS from the control node.
[apic]
apic-01 ansible_host=10.0.0.40

[apic:vars]
ansible_connection=local
# Provide via Ansible Vault:
# vault_aci_apic_hostname=10.0.0.40
# vault_aci_apic_username=admin
# vault_aci_apic_password="{{ vault }}"
