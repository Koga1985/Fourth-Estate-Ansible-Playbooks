# Example inventory for the Cisco NX-OS Switch STIG role.
# Copy to `inventory` and edit. Store credentials in Ansible Vault.
[nexus_switches]
nexus-01 ansible_host=10.0.0.61
nexus-02 ansible_host=10.0.0.62

[nexus_switches:vars]
ansible_network_os=cisco.nxos.nxos
ansible_connection=ansible.netcommon.network_cli
ansible_user=svc_ansible
# ansible_password="{{ vault_nxos_password }}"
