# Example inventory for the Cisco IOS XE Layer-2 STIG role.
# Copy to `inventory` and edit. Store credentials in Ansible Vault, not here.
#
#   cp inventory.example inventory
#   ansible-vault create group_vars/catalyst_l2_switches/vault.yml
#
[catalyst_l2_switches]
access-switch-01 ansible_host=10.0.0.51
access-switch-02 ansible_host=10.0.0.52

[catalyst_l2_switches:vars]
ansible_network_os=cisco.ios.ios
ansible_connection=ansible.netcommon.network_cli
ansible_user=svc_ansible
# Prefer vault: ansible_password="{{ vault_ios_password }}"
# ansible_password=CHANGE_ME
# ansible_become=true
# ansible_become_method=enable
# ansible_become_password="{{ vault_ios_enable }}"
