# Example inventory for the Cisco FTD (via FMC) STIG role.
# The role talks to FMC over HTTPS from the control node, so the FMC host runs
# with a local connection. Store credentials in Ansible Vault.
[fmc]
fmc-01 ansible_host=fmc.example.mil

[fmc:vars]
ansible_connection=local
fmc_host=fmc.example.mil
fmc_username=apiuser
# fmc_password="{{ vault_fmc_password }}"
fmc_validate_certs=true
