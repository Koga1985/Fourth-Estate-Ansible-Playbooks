{
  "report_type": "sdwan_security_hardening",
  "generated_at": "{{ ansible_date_time.iso8601 }}",
  "generated_by": "{{ ansible_user_id }}@{{ ansible_hostname }}",
  "deployment": {
    "organization": "{{ fourth_estate_org }}",
    "contact": "{{ fourth_estate_contact }}",
    "environment": "{{ fourth_estate_environment }}",
    "region": "{{ fourth_estate_region }}",
    "vmanage_host": "{{ sdwan_vmanage_host }}",
    "mode": "{{ apply_changes | ternary('applied', 'dry_run') }}"
  },
  "stig_references": [
    "Cisco IOS XE SD-WAN Router NDM STIG V2R1",
    "Cisco SD-WAN vManage NDM STIG V1R1"
  ],
  "compliance_frameworks": {{ compliance_frameworks | to_nice_json }},
  "stig_controls": {
    "CISC-ND-000080": {
      "title": "DoD Login Banner",
      "nist_control": "AC-8",
      "category": "CAT III",
      "status": "{{ enable_banners | ternary('configured', 'skipped') }}",
      "finding": "System use notification banner required"
    },
    "CISC-ND-000090": {
      "title": "SNMPv3 Required",
      "nist_control": "SC-8",
      "category": "CAT II",
      "status": "{{ enable_snmp_security | ternary('configured', 'skipped') }}",
      "finding": "SNMPv1/v2c must be disabled; SNMPv3 authPriv required",
      "snmpv1_disabled": {{ not sdwan_snmp_v1_enabled | lower }},
      "snmpv2_disabled": {{ not sdwan_snmp_v2c_enabled | lower }},
      "snmpv3_enabled": {{ sdwan_snmp_v3_enabled | lower }}
    },
    "CISC-ND-000200": {
      "title": "Session Idle Timeout",
      "nist_control": "AC-12",
      "category": "CAT II",
      "status": "{{ enable_session_management | ternary('configured', 'skipped') }}",
      "idle_timeout_minutes": {{ sdwan_session_idle_timeout // 60 }}
    },
    "CISC-ND-000370": {
      "title": "Account Lockout",
      "nist_control": "AC-7",
      "category": "CAT II",
      "status": "{{ enable_auth_hardening | ternary('configured', 'skipped') }}",
      "max_attempts": {{ sdwan_lockout_max_attempts }},
      "lockout_minutes": {{ sdwan_lockout_duration_seconds // 60 }}
    },
    "CISC-ND-000530": {
      "title": "Password Complexity",
      "nist_control": "IA-5",
      "category": "CAT I",
      "status": "{{ enable_password_policy | ternary('configured', 'skipped') }}",
      "min_uppercase": {{ sdwan_password_min_uppercase }},
      "min_lowercase": {{ sdwan_password_min_lowercase }},
      "min_digits": {{ sdwan_password_min_digits }},
      "min_special": {{ sdwan_password_min_special }}
    },
    "CISC-ND-000570": {
      "title": "Password Minimum Length",
      "nist_control": "IA-5",
      "category": "CAT I",
      "status": "{{ enable_password_policy | ternary('configured', 'skipped') }}",
      "min_length": {{ sdwan_password_min_length }},
      "compliant": {{ (sdwan_password_min_length >= 15) | lower }}
    },
    "CISC-ND-000700": {
      "title": "Audit Logging",
      "nist_control": "AU-2",
      "category": "CAT II",
      "status": "{{ enable_audit_logging | ternary('configured', 'skipped') }}",
      "syslog_destinations": {{ sdwan_syslog_destinations | length }}
    },
    "CISC-ND-001190": {
      "title": "AAA Authentication",
      "nist_control": "IA-2",
      "category": "CAT I",
      "status": "{{ enable_auth_hardening | ternary('configured', 'skipped') }}",
      "auth_method": "{{ sdwan_auth_method }}",
      "tacacs_servers": {{ sdwan_tacacs_servers | length }},
      "radius_servers": {{ sdwan_radius_servers | length }}
    },
    "CISC-ND-001290": {
      "title": "NTP Authentication",
      "nist_control": "AU-8",
      "category": "CAT II",
      "status": "{{ enable_ntp_hardening | ternary('configured', 'skipped') }}",
      "ntp_authenticate": {{ sdwan_ntp_authenticate | lower }},
      "ntp_servers": {{ sdwan_ntp_servers | length }}
    },
    "CISC-ND-001400": {
      "title": "SSH v2 / Disable Telnet",
      "nist_control": "SC-8",
      "category": "CAT II",
      "status": "{{ enable_ssh_hardening | ternary('configured', 'skipped') }}",
      "ssh_version": {{ sdwan_ssh_version }},
      "telnet_disabled": {{ sdwan_disable_telnet | lower }}
    },
    "CISC-ND-001440": {
      "title": "TLS and FIPS Cryptographic Controls",
      "nist_control": "SC-8",
      "category": "CAT I",
      "status": "{{ enable_crypto_tls | ternary('configured', 'skipped') }}",
      "http_disabled": {{ sdwan_disable_http_server | lower }},
      "min_tls_version": "{{ sdwan_min_tls_version }}",
      "fips_enabled": {{ sdwan_fips_enabled | lower }}
    }
  }
}
