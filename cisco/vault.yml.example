---
# Cisco ACI / ISE / UCS — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# You only need the sections for the platforms you are deploying.
# Minimum required: aci_* OR ise_* OR ucs_* (whichever you are running).

# ===========================================================================
# ACI (Application Centric Infrastructure)
# ===========================================================================
vault_aci_apic_hostname: "apic01.example.com"
vault_aci_apic_username: "ansible"
vault_aci_apic_password: "CHANGE_ME"

# ---- ACI LDAP integration (only needed for ldap role) ----------------------
vault_aci_ldap_host_1: "ldap01.example.com"
vault_aci_ldap_host_2: "ldap02.example.com"
vault_aci_ldap_bind_dn: "cn=svc-aci,ou=service,dc=example,dc=com"
vault_aci_ldap_bind_password: "CHANGE_ME"
vault_aci_ldap_base_dn: "dc=example,dc=com"

# ---- ACI SNMPv3 (only needed for monitoring role) ---------------------------
vault_aci_snmp_community: "CHANGE_ME"
vault_aci_snmp_auth_password: "CHANGE_ME"
vault_aci_snmp_priv_password: "CHANGE_ME"
vault_aci_snmpv3_auth_password: "CHANGE_ME"
vault_aci_snmpv3_priv_password: "CHANGE_ME"

# ---- ACI RADIUS / TACACS+ (only needed for AAA role) -----------------------
vault_aci_radius_host_1: "radius01.example.com"
vault_aci_radius_key: "CHANGE_ME"
vault_aci_tacacs_host_1: "tacacs01.example.com"
vault_aci_tacacs_key: "CHANGE_ME"

# ---- ACI misc ---------------------------------------------------------------
vault_aci_ntp_key: "CHANGE_ME"                # NTP authentication key
vault_aci_bgp_peer_password: "CHANGE_ME"      # BGP peer authentication MD5 password

# ---- ACI callhome (optional) ------------------------------------------------
vault_aci_callhome_customer_id: ""
vault_aci_callhome_contract_id: ""
vault_aci_callhome_site_id: ""
vault_aci_callhome_email: "ops@example.com"
vault_aci_callhome_smtp_server: "smtp.example.com"

# ===========================================================================
# ISE (Identity Services Engine)
# ===========================================================================
vault_ise_hostname: "ise01.example.com"
vault_ise_username: "ansible"
vault_ise_password: "CHANGE_ME"

# ===========================================================================
# UCS (Unified Computing System)
# ===========================================================================
vault_ucs_hostname: "ucs-fi-a.example.com"
vault_ucs_username: "ansible"
vault_ucs_password: "CHANGE_ME"

# ===========================================================================
# Cybervision (CyberVision Center — OT visibility)
# ===========================================================================
vault_cv_center_hostname: "cybervision.example.com"
vault_cv_admin_username: "admin"
vault_cv_admin_password: "CHANGE_ME"
vault_cv_api_token: "CHANGE_ME"
vault_cv_license_key: "CHANGE_ME"

# ===========================================================================
# Shared infrastructure credentials
# ===========================================================================
vault_vcenter_hostname: "vcenter.example.com"
vault_vcenter_username: "svc-cisco-ansible"
vault_vcenter_password: "CHANGE_ME"

vault_syslog_server: "syslog.example.com"
vault_snmp_community: "CHANGE_ME"
vault_snmp_trap_host: "snmp-mgr.example.com"
vault_siem_endpoint: "https://siem.example.com"
vault_siem_api_token: "CHANGE_ME"
vault_smtp_host: "smtp.example.com"

# Organization contact info (used in callhome / SNMP location)
vault_fourth_estate_contact: "ops@example.com"
vault_fourth_estate_email: "security@example.com"
vault_fourth_estate_address: "1234 Press Way, Washington DC"
vault_fourth_estate_phone: "+1-555-0100"
