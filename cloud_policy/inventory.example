# Cloud Computing SRG Assessment Inventory Example
# Copy this file to 'inventory' and customize for your environment:
#   cp inventory.example inventory
#
# The assessment is read-only and runs entirely on the control node:
#   ansible-playbook roles/cloud_computing_srg_assessment/playbooks/run.yml -i inventory

[localhost]
localhost ansible_connection=local

[localhost:vars]
# DoD impact level being assessed (IL2, IL4, IL5, IL6)
cloud_impact_level=IL4
