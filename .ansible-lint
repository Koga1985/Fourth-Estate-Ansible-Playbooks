# ansible-lint configuration for Fourth Estate Ansible Playbooks
#
# This is run as an INFORMATIONAL check in CI (it does not block merges yet),
# because the codebase predates linting and will surface findings that need to
# be triaged and ratcheted down over time. The enforced gate is yamllint +
# the YAML parse check (see .github/workflows/ci.yml).
#
# To make ansible-lint blocking once findings are addressed, set
# `continue-on-error: false` on the ansible-lint job in the workflow.
#
# Run locally:  ansible-lint
---
profile: basic

exclude_paths:
  - .git/
  - .github/
  - .vscode/
  - PRODUCTION_READINESS_ASSESSMENT.md

# Use the repo's yamllint config rather than ansible-lint's stricter built-in one.
use_default_rules: true
