# ansible-lint configuration for Fourth Estate Ansible Playbooks
#
# This is an ENFORCED gate in CI (see .github/workflows/ci.yml). It runs in
# --offline mode so results are deterministic regardless of Ansible Galaxy
# availability. Pre-existing findings are captured in .ansible-lint-ignore
# (a baseline ratchet): the current tree passes, and any NEW violation fails CI.
#
# A separate, INFORMATIONAL CI step installs the declared collections and runs
# the full `ansible-lint` + `ansible-playbook --syntax-check` (those rules need
# collections and a configured roles_path to resolve, which is not guaranteed on
# every runner).
#
# Run locally:  ansible-lint --offline <dir> [...]
---
profile: basic

exclude_paths:
  - .git/
  - .github/
  - .vscode/
  - docs/

# Rules intentionally skipped (with rationale), not bugs:
skip_list:
  # The repo convention names variables with a VENDOR prefix (e.g. tsc_*, ise_*),
  # not the ansible-lint-preferred per-role-name prefix. Renaming ~hundreds of
  # variables across 556 roles is an out-of-scope, high-risk refactor.
  - var-naming[no-role-prefix]
  # Task-name capitalization is cosmetic and does not affect execution.
  - name[casing]
  # YAML syntax/style is enforced by the dedicated yamllint job (.yamllint),
  # which is the single source of truth; avoid double-linting / config conflicts.
  - yaml
