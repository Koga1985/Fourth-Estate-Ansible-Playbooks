---
# Palo Alto Networks — Vault Variables Example
#
# Copy to group_vars/all/vault.yml and encrypt:
#   ansible-vault create group_vars/all/vault.yml
#
# NOTE: PAN-OS connection credentials (ansible_user / ansible_password) are set
# in your inventory file via httpapi connection variables. The variables below
# are for feature-specific secrets only.

# ---- Certificate management -------------------------------------------------
vault_cert_passphrase: "CHANGE_ME"       # Passphrase for importing/exporting TLS certs

# ---- MFA / RADIUS integration -----------------------------------------------
vault_duo_radius_secret: "CHANGE_ME"     # Duo RADIUS shared secret (if using Duo MFA)

# ---- SNMPv3 authentication --------------------------------------------------
vault_snmp_auth_password: "CHANGE_ME"    # SNMPv3 auth password (min 8 chars)
vault_snmp_priv_password: "CHANGE_ME"    # SNMPv3 privacy/encryption password
