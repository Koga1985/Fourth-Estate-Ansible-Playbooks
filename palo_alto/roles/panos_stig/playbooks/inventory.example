# Example inventory for the Palo Alto PAN-OS STIG role.
# The role talks to the PAN-OS XML API from the control node.
[panos_firewalls]
fw-01 ansible_host=10.0.0.40

[panos_firewalls:vars]
ansible_connection=local
panos_username=admin
# Prefer an API key (vaulted) over username/password:
# panos_api_key="{{ vault_panos_api_key }}"
# panos_password="{{ vault_panos_password }}"
